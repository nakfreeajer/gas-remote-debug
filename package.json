{
  "name": "gas-remote-debug",
  "version": "0.1.0",
  "description": "Generic raw-CDP helper for Google Apps Script remote debugging and OOPIF frame/context discovery",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakfreeajer/gas-remote-debug.git"
  },
  "bugs": {
    "url": "https://github.com/nakfreeajer/gas-remote-debug/issues"
  },
  "homepage": "https://github.com/nakfreeajer/gas-remote-debug#readme",
  "main": "src/index.js",
  "type": "commonjs",
  "bin": {
    "gas-remote-debug": "./bin/gas-remote-debug.js"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/",
    "bin/",
    "examples/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "cli": "node bin/gas-remote-debug.js",
    "test": "node --test tests/*.test.js",
    "check": "node --check src/index.js && node --check bin/gas-remote-debug.js",
    "prepublishOnly": "npm run check && npm test"
  },
  "keywords": [
    "cdp",
    "chrome-devtools-protocol",
    "google-apps-script",
    "gas",
    "oopif",
    "iframe",
    "remote-debugging",
    "testing",
    "validation"
  ],
  "peerDependencies": {
    "ws": ">=8"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  }
}
